---
import "../styles/genel.css";
import "../styles/gezinti.css";
import { çeviriAl, type Dil } from "../i18n/utils";
import YükleniyorAnimasyon from "../components/YükleniyorAnimasyon.astro";
import Gezinti from "../components/Gezinti.astro";
import AltBilgi from "../components/AltBilgi.astro";
import HenüzHazırDeğilPopup from "../components/HenüzHazırDeğilPopup.astro";

interface Props {
  başlık: string;
  dil: Dil;
  açıklama?: string;
  ogGörsel?: string;
}

const { başlık, dil, açıklama, ogGörsel } = Astro.props;
const ogGörselUrl = new URL(
  ogGörsel ?? "/assets/og-varsayılan.png",
  Astro.site,
).toString();
const sayfaUrl = new URL(Astro.url.pathname, Astro.site).toString();
const ogBaşlık = `${başlık} — Marco La'datema`;
const t = çeviriAl(dil);
---

<!doctype html>
<html lang={dil}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{başlık} — Marco La'datema</title>

    <meta name="description" content={açıklama ?? ""} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={sayfaUrl} />
    <meta property="og:title" content={ogBaşlık} />
    <meta property="og:description" content={açıklama ?? ""} />
    <meta property="og:image" content={ogGörselUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={dil === "tr" ? "tr_TR" : "en_US"} />
    <meta property="og:site_name" content="Marco La'datema" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={sayfaUrl} />
    <meta name="twitter:title" content={ogBaşlık} />
    <meta name="twitter:description" content={açıklama ?? ""} />
    <meta name="twitter:image" content={ogGörselUrl} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <script is:inline>
      const tema = localStorage.getItem("tema") ?? "otomatik";
      const koyuMu =
        tema === "koyu" ||
        (tema === "otomatik" &&
          window.matchMedia("(prefers-color-scheme: dark)").matches);
      document.documentElement.setAttribute(
        "data-tema",
        koyuMu ? "koyu" : "açık",
      );
    </script>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css"
    />
  </head>
  <body>
    <YükleniyorAnimasyon />
    <Gezinti dil={dil} t={t} />
    <main>
      <slot />
    </main>
    <AltBilgi dil={dil} t={t} />
    <HenüzHazırDeğilPopup dil={dil} />
  </body>
</html>
